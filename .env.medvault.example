# MedVault environment — copy to .env.medvault and adjust as needed.
# Used by: docker compose -f docker-compose.medvault.yml --env-file .env.medvault up -d

# ── VaultDB ──────────────────────────────────────────────────────────
VAULTDB_TOKEN=vdb_sk_medvault_demo_token_2025
VAULTDB_LOG_LEVEL=info
VAULTDB_AUTH_ENABLED=true

# ── API Gateway ──────────────────────────────────────────────────────
JWT_SECRET=medvault_jwt_secret_change_in_production_please
JWT_TTL_HOURS=24

# ── Frontend ─────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000

# ── Seed ─────────────────────────────────────────────────────────────
SEED_PATIENTS=50
SEED_DOCTORS=10
