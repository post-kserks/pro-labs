# Build context exclusions for Docker
# Reduces image build time and context size

# Version control
.git
.gitignore
.github

# Documentation
*.md
LICENSE
ARCHITECTURE.md
task.md

# Data directories
data/

# IDE/editor files
.mimocode/
.vscode/
.idea/
*.swp
*.swo
*~

# Go build artifacts
server/vendor/
server/benchmark
server/check-index

# Client code (not needed for server build)
client/
tools/

# Docker files (don't copy into build context)
docker-compose.yml
Dockerfile
.dockerignore

# Runtime files
run.sh
build.sh
Makefile
VERSION
vaultdb.yaml
