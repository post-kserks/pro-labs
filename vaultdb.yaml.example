server:
  host: 0.0.0.0
  port: 5432
  http_port: 8080
  monitor_port: 5433
  # Максимальный размер одного запроса по TCP-протоколу
  max_request_size_bytes: 67108864  # 64 МБ
  live_queries:
    # Размер буфера канала каждой подписки
    buffer_size: 256
    # Что делать, когда клиент не успевает читать обновления:
    #   drop  — отбросить обновление (с логированием)
    #   block — ждать до block_timeout_s, затем отписать клиента
    #   evict — вытеснить старейшее обновление и положить новое
    drop_policy: "evict"
    block_timeout_s: 5

storage:
  # page — бинарное страничное хранилище (по умолчанию, рекомендуется)
  # json — хранилище на JSON-файлах (legacy, для совместимости)
  # Примечание: вторичные индексы пока поддерживаются только в json engine
  engine: "page"
  data_dir: /data

auth:
  enabled: true
  # Allow localhost requests without authentication (default: true).
  # Set to false in production to require tokens for all connections.
  localhost_bypass: true

# TLS configuration.
# tls:
#   enabled: true
#   cert_file: /path/to/cert.pem
#   key_file: /path/to/key.pem
#   min_version: "1.2"
#   enforce: true          # Reject non-TLS connections
#   redirect_http: true    # Auto redirect HTTP to HTTPS

# Внешний embedding-провайдер для SEMANTIC_MATCH и AI_EMBED.
# Если секция не заполнена, SEMANTIC_MATCH возвращает понятную ошибку.
ai:
  provider: ""        # "openai" или "ollama"
  endpoint: ""        # например https://api.openai.com/v1/embeddings или http://localhost:11434/api/embeddings
  model: ""           # например text-embedding-3-small или nomic-embed-text
  api_key: ""         # или переменная окружения VAULTDB_AI_API_KEY
